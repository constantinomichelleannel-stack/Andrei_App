{
  "entities": {
    "users": {
      "title": "User",
      "description": "A lawyer user of the LexPH platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "Full name of the lawyer" },
        "rollNumber": { "type": "string", "description": "Supreme Court Roll of Attorneys number" },
        "specialization": { "type": "string", "description": "Primary legal specialization" },
        "role": { "type": "string", "enum": ["lawyer", "admin"], "description": "User role" },
        "privacyConsent": { "type": "boolean", "description": "Whether the user has accepted the data privacy consent" },
        "consentDate": { "type": "string", "format": "date-time", "description": "When the consent was given" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "displayName", "privacyConsent", "role"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "users",
      "description": "Individual lawyer profile documents."
    }
  }
}
